# 가족 추억 보관 상자 - 환경 설정
# 이 파일을 수정하여 개인 환경에 맞게 설정하세요

# === 서버 설정 ===
HOST=0.0.0.0
PORT=8000
DEBUG=True

# === 보안 ===
# 아래 값은 서버 시작 시 자동 생성됩니다 (직접 설정도 가능)
# SECRET_KEY=your-secret-key-here

# === 저장소 경로 ===
# Windows 예시:
EXTERNAL_DRIVE_PATH=X:/
TEMP_BUFFER_PATH=C:/PhotoBuffer/temp
DATA_DIR=C:/PhotoBuffer/data
FACE_DATA_DIR=C:/PhotoBuffer/faces

# Linux/라즈베리파이 예시:
# EXTERNAL_DRIVE_PATH=/mnt/usb
# TEMP_BUFFER_PATH=/home/pi/PhotoBuffer/temp
# DATA_DIR=/home/pi/PhotoBuffer/data
# FACE_DATA_DIR=/home/pi/PhotoBuffer/faces

# === 썸네일 ===
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=320
THUMBNAIL_QUALITY=75

# === 외장하드 감지 간격 (초) ===
DRIVE_CHECK_INTERVAL=5

# === 카카오 로컬 API (100% 무료, 일 10만 건) ===
# https://developers.kakao.com → 앱 등록 → REST API 키
KAKAO_REST_API_KEY=

# === Cloudflare Pages 배포 (100% 무료) ===
# wrangler login 후 토큰 입력 (선택적)
CLOUDFLARE_PROJECT_NAME=family-photo-archive
CLOUDFLARE_API_TOKEN=
